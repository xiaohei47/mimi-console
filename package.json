{
  "name": "ant-design-pro",
  "version": "6.0.1",
  "private": true,
  "description": "An out-of-box UI solution for enterprise applications",
  "repository": "git@github.com:ant-design/ant-design-pro.git",
  "scripts": {
    "build": "max build",
    "dev": "cross-env UMI_ENV=dev MOCK=none max dev",
    "lint": "tsc --noEmit",
    "start": "cross-env UMI_ENV=dev max dev",
    "tsc": "tsc --noEmit"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@ant-design/pro-components": "^3.1.12-0",
    "@rc-component/util": "^1.11.0",
    "@tanstack/react-query": "^5.100.6",
    "antd": "^6.4.3",
    "antd-style": "^4.1.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@ant-design/cli": "^6.4.3",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@umijs/lint": "^4.6.51",
    "@umijs/max": "^4.6.51",
    "cross-env": "^10.1.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "create-umi": {
    "ignoreScript": [
      "docker*",
      "functions*",
      "site",
      "generateMock"
    ],
    "ignoreDependencies": [
      "netlify*",
      "serverless"
    ],
    "ignore": [
      ".dockerignore",
      ".git",
      ".github",
      ".gitpod.yml",
      "CODE_OF_CONDUCT.md",
      "Dockerfile",
      "Dockerfile.*",
      "lambda",
      "LICENSE",
      "netlify.toml",
      "README.*.md",
      "azure-pipelines.yml",
      "docker",
      "CNAME",
      "create-umi"
    ]
  }
}
